generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String?
  passwordHash   String?
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  sessions       Session[]
  location       UserLocation?
  favorites      UserFavorite[]
  followed       UserFollowedSatellite[]
  alerts         AlertPreference[]
  recentlyViewed RecentlyViewed[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Satellite {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  noradId          String?
  agency           String
  country          String
  category         String
  missionType      String?
  description      String
  shortDescription String?
  launchDate       String?
  orbitType        String?
  status           String   @default("active")
  tleLine1         String?
  tleLine2         String?
  imageUrl         String?
  seoTitle         String?
  seoDescription   String?
  altitude         String?
  inclination      String?
  factsJson        String?
  timelineJson     String?
  relatedSlugs     String?
  featured         Boolean  @default(false)
  feedPriority     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  model            ModelAsset?
  favorites        UserFavorite[]
  followed         UserFollowedSatellite[]
  alerts           AlertPreference[]
  recentlyViewed   RecentlyViewed[]
  feedItems        FeedItem[]
}

model ModelAsset {
  id                   String    @id @default(cuid())
  satelliteId          String    @unique
  satellite            Satellite @relation(fields: [satelliteId], references: [id], onDelete: Cascade)
  modelUrl             String?
  embedUid             String?
  fallbackType         String    @default("procedural")
  attribution          String
  sourceUrl            String?
  license              String?
  commercialUseAllowed Boolean   @default(false)
  modificationAllowed  Boolean   @default(false)
  partsJson            String?
}

model EducationPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  agency      String
  summary     String
  bodyJson    String?
  modelKey    String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quiz {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String?
  questions   QuizQuestion[]
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question      String
  optionsJson   String
  correctIndex  Int
  explanation   String?
}

model FeedItem {
  id          String     @id @default(cuid())
  satelliteId String?
  satellite   Satellite? @relation(fields: [satelliteId], references: [id], onDelete: SetNull)
  title       String
  summary     String
  agency      String
  missionType String?
  orbitType   String?
  category    String
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

model TleCache {
  id        String   @id @default("global")
  source    String
  rawTle    String
  updatedAt DateTime @default(now())
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  label     String?
  updatedAt DateTime @updatedAt
}

model UserFavorite {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  satelliteId String
  satellite   Satellite @relation(fields: [satelliteId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, satelliteId])
}

model UserFollowedSatellite {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  satelliteId String
  satellite   Satellite @relation(fields: [satelliteId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, satelliteId])
}

model AlertPreference {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  satelliteId     String
  satellite       Satellite @relation(fields: [satelliteId], references: [id], onDelete: Cascade)
  minutesBefore   Int       @default(10)
  emailEnabled    Boolean   @default(false)
  pushEnabled     Boolean   @default(true)
  lastNotifiedAt  DateTime?
  createdAt       DateTime  @default(now())

  @@unique([userId, satelliteId])
}

model RecentlyViewed {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  satelliteId String
  satellite   Satellite @relation(fields: [satelliteId], references: [id], onDelete: Cascade)
  viewedAt    DateTime  @default(now())

  @@unique([userId, satelliteId])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String?
  alertId   String?
  channel   String
  status    String
  message   String?
  createdAt DateTime @default(now())
}
